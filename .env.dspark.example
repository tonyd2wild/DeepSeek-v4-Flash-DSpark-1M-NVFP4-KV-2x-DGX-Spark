# DeepSeek V4 Flash DSpark C12 NVFP4 profile for 2x DGX Spark TP=2.
# Copy to .env.dspark on each node and adjust node-specific values.

# Cluster
WORKER_HOST=worker-host-or-roce-ip
# Worker-local checkout/deployment path. Leave blank to mirror the head path.
WORKER_DIR=
# Optional explicit worker checkout path. This is useful when the worker clone
# lives somewhere different from the head checkout; it takes precedence over
# WORKER_DIR when set.
WORKER_SCRIPT_DIR=
MASTER_ADDR=head-roce-ip
MASTER_PORT=25000
NODE_RANK=0
HEADLESS=

# Worker node should use:
# NODE_RANK=1
# HEADLESS=1

# RoCE / InfiniBand
NCCL_IB_HCA=rocepXsYfZ
NCCL_SOCKET_IFNAME=enpXsYfZnpN
NCCL_IB_GID_INDEX=0
NCCL_CROSS_NIC=1

# Caches / model
HF_CACHE=${HOME}/.cache/huggingface
# Optional worker-local Hugging Face cache. Use this when the worker user/path
# differs from the head node. If blank, the worker uses HF_CACHE.
WORKER_HF_CACHE=
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
HF_HUB_DISABLE_XET=1
DSPARK_MODEL=deepseek-ai/DeepSeek-V4-Flash-DSpark
SERVED_MODEL_NAME=deepseek-v4-flash-dspark
# Bind to 0.0.0.0 when Hermes/OpenClaw or another machine must reach the API.
# For a head-node-only test, set this back to 127.0.0.1.
VLLM_HOST=0.0.0.0
# Explicit per-node host IPs prevent distributed vLLM/ZeroMQ from binding the
# worker to the head node's fabric address. Set these to each node's RoCE IP.
VLLM_HOST_IP=head-roce-ip
WORKER_VLLM_HOST_IP=worker-roce-ip

# Runtime image built by ./build-dspark-vllm-runtime.sh.
DSPARK_VLLM_IMAGE=vllm-dspark-runtime:dspark-nvfp4-stage-c

# Validated Keys C12 NVFP4 profile.
MAX_MODEL_LEN=1500000
MAX_NUM_SEQS=12
MAX_NUM_BATCHED_TOKENS=8192
GPU_MEMORY_UTILIZATION=0.85
MTP_NUM_TOKENS=5

# Deterministic server defaults. Do not inherit model-card sampling defaults
# for agent serving. Explicit client request parameters still win.
GENERATION_TEMPERATURE=0.0
GENERATION_TOP_P=1.0
GENERATION_TOP_K=40
GENERATION_REPETITION_PENALTY=1.05

# Higher-throughput short-context profile from the Keys concurrency patch:
# MAX_MODEL_LEN=200000
# MAX_NUM_SEQS=16
# VLLM_USE_B12X_WO_PROJECTION=1
#
# Conservative prior agent lane:
# MAX_MODEL_LEN=1048576
# MAX_NUM_SEQS=6
# GPU_MEMORY_UTILIZATION=0.80
#
# Context and concurrency share one KV pool. The validated C12 lane reported a
# 3.225M-token KV pool, or 2.15x maximum concurrency for 1.5M-token requests.
# Normal agent turns are much shorter than the maximum, so 12 slots are useful;
# multiple simultaneous full-context requests will still queue.

# DSpark and B12X switches from the validated 1M run.
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_WO_PROJECTION=1
VLLM_DSPARK_CONFIDENCE_THRESHOLD=0.0
VLLM_DSPARK_CONFIDENCE_SCHEDULER=off
VLLM_DSPARK_LOCAL_ARGMAX=1
VLLM_DSPARK_REPLICATE_MARKOV_W1=1
VLLM_DSPARK_FUSED_MARKOV_ARGMAX=0
VLLM_DSPARK_GPU_REJECTED_CONTEXT_MASK=1
VLLM_DSPARK_REFERENCE_KV_QUANT_DEQUANT=0
VLLM_DSPARK_HARDWARE_SCHEDULER_EARLY_STOP=1
VLLM_B12X_W4A16_FORCE_BLOCKS_PER_SM=0
VLLM_B12X_W4A16_FORCE_BLOCKS_MAX_M=16
VLLM_B12X_W4A16_FORCE_TILE_CONFIG=
B12X_W4A16_TC_DECODE=0
VLLM_DSV4_B12X_COMPRESSED_MLA=0
VLLM_DSV4_DSPARK_DEFER_TARGET_CAPTURE=0
VLLM_DSV4_DSPARK_DEFER_TARGET_CAPTURE_EXACT=0

# Runtime defaults.
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
VLLM_SPARSE_INDEXER_MAX_LOGITS_MB=256
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a
FLASHINFER_DISABLE_VERSION_CHECK=1
TILELANG_CLEANUP_TEMP_FILES=1
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/opt/env/bin/nvcc
NCCL_NET=IB
NCCL_IB_DISABLE=0
NCCL_CUMEM_ENABLE=0
NCCL_IGNORE_CPU_AFFINITY=1
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
VLLM_SKIP_INIT_MEMORY_CHECK=1
